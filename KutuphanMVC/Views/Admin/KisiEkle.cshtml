@{
    ViewData["Title"] = "KisiEkle";
}

@model Kullanici
<!DOCTYPE html>
<html lang="tr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Şehir Kütüphanesi - Üye Kayıt</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .library-header {
            background-color: #343a40;
            color: white;
            padding: 1rem 0;
            margin-bottom: 2rem;
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.85);
        }

        .nav-link:hover {
            color: white;
        }

        .register-container {
            max-width: 500px;
            margin: 0 auto;
            padding: 2rem;
            background: white;
            border-radius: 8px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
        }

        .register-title {
            color: #343a40;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .btn-library {
            background-color: #6c757d;
            border-color: #6c757d;
            color: white;
        }

        .btn-library:hover {
            background-color: #5a6268;
            border-color: #545b62;
            color: white;
        }

        .footer {
            background-color: #343a40;
            color: white;
            padding: 2rem 0;
            margin-top: 3rem;
        }
    </style>
</head>

<body>
    <!-- Header/Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="#"><strong>Şehir</strong> <span class="text-danger">Kütüphanesi</span></a>
            <div class="collapse navbar-collapse justify-content-end">
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Anasayfa">Ana Sayfa</a>
                    </li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Hakkimizda">Kitaplar</a>
                    </li>

                </ul>
            </div>
        </div>

    </nav>
    <!-- Main Content -->
    <main class="container">
        <div class="register-container">
            <h2 class="register-title">Üye Ekle Formu</h2>

            <form asp-action="KisiEkle" method="post"  enctype="multipart/form-data" model>
                <!-- Kişisel Bilgiler -->
                <div class="mb-3">
                    <label for="username" class="form-label">Kullanıcı Adı</label>
                    <input type="text" class="form-control" asp-for="KullaniciAd" required>
                    <div class="form-text">Kütüphane sisteminde görünecek isminiz</div>
                </div>





                <!-- İletişim Bilgileri -->
                <div class="mb-3">
                    <label for="email" class="form-label">E-posta Adresi</label>
                    <input type="email" class="form-control" asp-for="KullaniciEmail" required>
                </div>

                <div class="mb-3">
                    <label for="phone" class="form-label">Telefon Numarası</label>
                    <input type="tel" class="form-control" asp-for="KullaniciTel" pattern="[0-9]{10}" required>
                    <div class="form-text">Başında 0 olmadan 10 haneli numaranızı giriniz</div>
                </div>
                <div class="mb-3">
                    <label for="pasword" class="form-label">Sifre</label>
                    <input type="text" class="form-control" asp-for="KullaniciSifre">
                </div>
                <div>
                    <label for="formFileLg" class="form-label">Resim ekleyin</label>
                    <input class="form-control form-control-lg" id="formFileLg" type="file"asp-for="KullaniciRol">
                </div>





                <input type="submit" class="btn btn-library w-100" value="Kayıt Ol">
            </form>

            <hr class="my-4">

            <div class="text-center">
                <p>Zaten üye misiniz? <a asp-controller="GKsistem" asp-action="Giris" class="text-decoration-none">Giriş
                        Yapın</a></p>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5 class="mb-3">Şehir Kütüphanesi</h5>
                    <p>Bilgiye erişimi kolaylaştırmak ve okuma kültürünü yaygınlaştırmak için hizmet veriyoruz.</p>
                </div>
                <div class="col-md-2">
                    <h5 class="mb-3">Hızlı Linkler</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-white text-decoration-none">Ana Sayfa</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Kitaplar</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Etkinlikler</a></li>
                        <li><a href="#" class="text-white text-decoration-none">İletişim</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5 class="mb-3">Hizmetler</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="text-white text-decoration-none">Kitap Ödünç Alma</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Dijital Kütüphane</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Araştırma Yardımı</a></li>
                        <li><a href="#" class="text-white text-decoration-none">Çocuk Programları</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h5 class="mb-3">İletişim</h5>
                    <address>
                        Cumhuriyet Cad. No:123, Şehir<br>
                        Tel: (123) 456 78 90<br>
                        Email: info@sehrkutuphanesi.org
                    </address>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>