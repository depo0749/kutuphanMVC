@{
    ViewData["Title"] = "KitapGuncelle";
}
@model Kitap
<script type="text/javascript">
        var gk_isXlsx = false;
        var gk_xlsxFileLookup = {};
        var gk_fileData = {};
        function filledCell(cell) {
          return cell !== '' && cell != null;
        }
        function loadFileData(filename) {
        if (gk_isXlsx && gk_xlsxFileLookup[filename]) {
            try {
                var workbook = XLSX.read(gk_fileData[filename], { type: 'base64' });
                var firstSheetName = workbook.SheetNames[0];
                var worksheet = workbook.Sheets[firstSheetName];

                // Convert sheet to JSON to filter blank rows
                var jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1, blankrows: false, defval: '' });
                // Filter out blank rows (rows where all cells are empty, null, or undefined)
                var filteredData = jsonData.filter(row => row.some(filledCell));

                // Heuristic to find the header row by ignoring rows with fewer filled cells than the next row
                var headerRowIndex = filteredData.findIndex((row, index) =>
                  row.filter(filledCell).length >= filteredData[index + 1]?.filter(filledCell).length
                );
                // Fallback
                if (headerRowIndex === -1 || headerRowIndex > 25) {
                  headerRowIndex = 0;
                }

                // Convert filtered JSON back to CSV
                var csv = XLSX.utils.aoa_to_sheet(filteredData.slice(headerRowIndex)); // Create a new sheet from filtered array of arrays
                csv = XLSX.utils.sheet_to_csv(csv, { header: 1 });
                return csv;
            } catch (e) {
                console.error(e);
                return "";
            }
        }
        return gk_fileData[filename] || "";
        }
        </script><!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Şehir Kütüphanesi</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: #f4f4f4;
        }

        /* Sidebar Stili */
        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            padding: 20px;
            position: fixed;
            height: 100%;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sidebar h2 {
            font-size: 24px;
            margin-bottom: 20px;
            text-align: center;
        }

        .sidebar ul {
            list-style: none;
            flex: 1;
        }

        .sidebar ul li {
            margin: 15px 0;
        }

        .sidebar ul li a {
            color: white;
            text-decoration: none;
            font-size: 18px;
            display: block;
            padding: 10px;
            border-radius: 5px;
            transition: background 0.3s;
        }

        .sidebar ul li a:hover {
            background-color: #34495e;
        }

        /* Çıkış Butonu Stili */
        .logout-btn {
            background-color: #e74c3c;
            color: white;
            text-decoration: none;
            font-size: 18px;
            padding: 10px;
            text-align: center;
            border-radius: 5px;
            margin-top: 20px;
            display: block;
            transition: background 0.3s;
        }

        .logout-btn:hover {
            background-color: #c0392b;
        }

        /* Active Stil Sınıfı */
        .active {
            background-color: #e74c3c;
            color: white;
            text-decoration: none;
            font-size: 18px;
            padding: 10px;
            text-align: center;
            border-radius: 5px;
            display: block;
            transition: background 0.3s;
        }

        .active:hover {
            background-color: #c0392b;
        }

        /* Ana İçerik Alanı */
        .main-content {
            margin-left: 270px;
            padding: 20px;
            flex: 1;
        }

        .main-content h1 {
            color: #2c3e50;
            margin-bottom: 20px;
        }

        .main-content p {
            font-size: 16px;
            line-height: 1.6;
            color: #333;
            margin-bottom: 15px;
        }

        .card {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }
         .btn-library {
            background-color: #eb1010;
            border-color: #eb1010;
            color: white;
        }
        .hr:hover{
            color: red;
        }
        .hl:hover{
            color: red;
        }
        .btn-library:hover {
            background-color: #5a6268;
            border-color: #545b62;
            color: white;
        }
         .register-container {
            max-width: 500px;
            margin: 0 auto;
            padding: 2rem;
            background: white;
            border-radius: 8px;
            box-shadow: 0 0 15px rgba(0, 0, 0, 0.1);
        }

        .register-title {
            color: #343a40;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        .btn-library {
            background-color: #6c757d;
            border-color: #6c757d;
            color: white;
        }

        .btn-library:hover {
            background-color: #5a6268;
            border-color: #545b62;
            color: white;
        }
        


    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h2>Şehir Kütüphanesi</h2>
        <ul>
           <li ><a class="active" asp-controller="Admin"asp-action="Kisiler">Kullanicilar</a></li>
            <li><a asp-controller="Admin"asp-action="Kitaplar">Kitaplar</a></li>
            <li><a href="#etkinlikler">EmanetKitaplar</a></li>
           <li><a href="#iletisim">İletişim</a></li>
        </ul>
      <a asp-controller="Home" asp-action="Anasayfa" class="logout-btn" id="logout">Çıkış</a>
    </div>

    <!-- Ana İçerik -->
    <div class="main-content ">
        <main class="container">
        <div class="register-container">
            <h2 class="register-title">Üye Guncelle Formu</h2>

            <form asp-action="KitapGuncelle" method="post" enctype="multipart/form-data" model>
                <!-- Kişisel Bilgiler -->
                  <div class="mb-3">
                    <label for="username" class="form-label">Kullanıcı Adı</label>
                    <input type="text" class="form-control" asp-for="KitapAd" value="@Model.KitapAd" required>
                    <div class="form-text">Kütüphane sisteminde görünecek Kitapbin isminiz</div>
                </div>
                  <div class="mb-3">
                    <label for="username" class="form-label">Yazar Adi</label>
                    <input type="text" class="form-control" asp-for="YazarAd" value="@Model.YazarAd" required>
                    <div class="form-text">Kütüphane sisteminde görünecek Kitapbin Yazar Adi</div>
                </div>
                   <div class="mb-3">
                    <label for="username" class="form-label">Yayinevi Adı</label>
                    <input type="text" class="form-control" asp-for="Yayinevi" value="@Model.Yayinevi" required>
                    <div class="form-text">Kütüphane sisteminde görünecek Kitapbin Yayinevi</div>
                </div>
                   <div class="mb-3">
                    <label for="username" class="form-label">Kitap Turu Adı</label>
                    <input type="text" class="form-control" asp-for="KitapTuru"  value="@Model.KitapTuru" required>
                    <div class="form-text">Kütüphane sisteminde görünecek Kitapbin Turu</div>
                </div>
                   <div class="mb-3">
                    <label for="number" class="form-label">Kitap SayfaSayisi</label>
                    <input type="number" class="form-control" asp-for="KitapSayfaSayisi"  value="@Model.KitapSayfaSayisi" required>
                    <div class="form-text">Kütüphane sisteminde görünecek Kitapbin SayfaSayisi</div>
                </div>





                <!-- İletişim Bilgileri -->
               
                <div>
                    <label for="formFileLg" class="form-label">Resim ekleyin</label>
                    <input class="form-control form-control-lg"  type="file"asp-for="KapakFoto" value="@Model.KapakFoto" required>
                </div>



                <input type="submit" class="btn btn-library w-100" value="Kayıt Ol">
            </form>

            <hr class="my-4">

            <div class="text-center">
                <p> <a asp-controller="Admin" asp-action="Kisiler" class="text-decoration-none">Geri
                        Dön</a></p>
            </div>
        </div>
    </main>
    </div>
    </div>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        
    </script>
</body>
</html>