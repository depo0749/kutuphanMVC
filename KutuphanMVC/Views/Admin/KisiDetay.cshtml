@{
    ViewData["Title"] = "KisiDetay";
}
@model Kullanici

<script type="text/javascript">
        var gk_isXlsx = false;
        var gk_xlsxFileLookup = {};
        var gk_fileData = {};
        function filledCell(cell) {
          return cell !== '' && cell != null;
        }
        function loadFileData(filename) {
        if (gk_isXlsx && gk_xlsxFileLookup[filename]) {
            try {
                var workbook = XLSX.read(gk_fileData[filename], { type: 'base64' });
                var firstSheetName = workbook.SheetNames[0];
                var worksheet = workbook.Sheets[firstSheetName];

                // Convert sheet to JSON to filter blank rows
                var jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1, blankrows: false, defval: '' });
                // Filter out blank rows (rows where all cells are empty, null, or undefined)
                var filteredData = jsonData.filter(row => row.some(filledCell));

                // Heuristic to find the header row by ignoring rows with fewer filled cells than the next row
                var headerRowIndex = filteredData.findIndex((row, index) =>
                  row.filter(filledCell).length >= filteredData[index + 1]?.filter(filledCell).length
                );
                // Fallback
                if (headerRowIndex === -1 || headerRowIndex > 25) {
                  headerRowIndex = 0;
                }

                // Convert filtered JSON back to CSV
                var csv = XLSX.utils.aoa_to_sheet(filteredData.slice(headerRowIndex)); // Create a new sheet from filtered array of arrays
                csv = XLSX.utils.sheet_to_csv(csv, { header: 1 });
                return csv;
            } catch (e) {
                console.error(e);
                return "";
            }
        }
        return gk_fileData[filename] || "";
        }
        </script><!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Şehir Kütüphanesi</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body {
            display: flex;
            min-height: 100vh;
            background-color: #f4f4f4;
        }

        /* Sidebar Stili */
        .sidebar {
            width: 250px;
            background-color: #2c3e50;
            color: white;
            padding: 20px;
            position: fixed;
            height: 100%;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sidebar h2 {
            font-size: 24px;
            margin-bottom: 20px;
            text-align: center;
        }

        .sidebar ul {
            list-style: none;
            flex: 1;
        }

        .sidebar ul li {
            margin: 15px 0;
        }

        .sidebar ul li a {
            color: white;
            text-decoration: none;
            font-size: 18px;
            display: block;
            padding: 10px;
            border-radius: 5px;
            transition: background 0.3s;
        }

        .sidebar ul li a:hover {
            background-color: #34495e;
        }

        /* Çıkış Butonu Stili */
        .logout-btn {
            background-color: #e74c3c;
            color: white;
            text-decoration: none;
            font-size: 18px;
            padding: 10px;
            text-align: center;
            border-radius: 5px;
            margin-top: 20px;
            display: block;
            transition: background 0.3s;
        }

        .logout-btn:hover {
            background-color: #c0392b;
        }

        /* Active Stil Sınıfı */
        .active {
            background-color: #e74c3c;
            color: white;
            text-decoration: none;
            font-size: 18px;
            padding: 10px;
            text-align: center;
            border-radius: 5px;
            display: block;
            transition: background 0.3s;
        }

        .active:hover {
            background-color: #c0392b;
        }

        /* Ana İçerik Alanı */
        .main-content {
            margin-left: 270px;
            padding: 20px;
            flex: 1;
        }

        .main-content h1 {
            color: #2c3e50;
            margin-bottom: 20px;
        }

        .main-content p {
            font-size: 16px;
            line-height: 1.6;
            color: #333;
            margin-bottom: 15px;
        }

        .card {
            background-color: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            margin-bottom: 20px;
        }
         .btn-library {
            background-color: #eb1010;
            border-color: #eb1010;
            color: white;
        }
        .hr:hover{
            color: red;
        }
        .hl:hover{
            color: red;
        }
        .btn-library:hover {
            background-color: #5a6268;
            border-color: #545b62;
            color: white;
        }


    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <h2>Şehir Kütüphanesi</h2>
        <ul>
                <li ><a class="active" asp-controller="Admin"asp-action="Kisiler">Kullanicilar</a></li>
            <li><a asp-controller="Admin"asp-action="Kitaplar">Kitaplar</a></li>
            <li><a href="#etkinlikler">EmanetKitaplar</a></li>
           <li><a href="#iletisim">İletişim</a></li>
        </ul>
       <a asp-controller="Home" asp-action="Anasayfa" class="logout-btn" id="logout">Çıkış</a>
    </div>

    <!-- Ana İçerik -->
    <div class="main-content ">
          <a asp-controller="Admin" asp-action="KisiEkle"><input type="button" class="btn btn-library w-100" value="+Ekle" ></a> 
          <div class="container mt-5"></div>
        <div class="card mx-auto shadow" style="max-width: 400px;">
            <div class="card-body text-center">
                <!-- Başlık -->
                <h4 class="card-title mb-3">Kullanıcı Bilgi</h4>
                <hr class="my-3 mx-n3">
                
                <!-- Fotoğraf -->
                <img src="~/resim/@Model.Resimadi" class="rounded-circle mb-3" alt="Kullanıcı Fotoğrafı" style="width: 150px; height: 150px;">
                
                <!-- Ad -->
                <h5 class="card-title">@Model.KullaniciAd</h5>
                
                <!-- Üst Çizgi -->
                <hr class="my-4 mx-n3">
                
                <!-- Kullanıcı Bilgileri -->
                <p class="card-text text-muted">E-posta: @Model.KullaniciEmail</p>
                <p class="card-text text-muted">Telefon: @Model.KullaniciTel</p>
                <p class="card-text text-muted">Şifre: @Model.KullaniciSifre</p>
                
                <!-- Alt Çizgi -->
                <hr class="my-4 mx-n3">
                
                <!-- Geri Dön Butonu -->                                                                
                <a asp-controller="Admin" asp-action="Kisiler" class="btn btn-primary">Geri Dön</a>
            </div>
        </div>
    </div>
    </div>
      <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        
    </script>
</body>
</html>